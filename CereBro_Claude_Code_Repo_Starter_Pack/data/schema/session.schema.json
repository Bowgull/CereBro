{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Session",
  "type": "object",
  "required": [
    "id",
    "status",
    "started_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "project_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "task_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "active",
        "paused",
        "complete",
        "abandoned"
      ]
    },
    "active_agent": {
      "type": [
        "string",
        "null"
      ]
    },
    "current_mode": {
      "type": [
        "string",
        "null"
      ]
    },
    "started_at": {
      "type": "string"
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_activity_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_action": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
