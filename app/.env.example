# ── CereBro harness DB ────────────────────────────────────────────
# Local sqlite by default. Swap to libsql:// for Turso, no code change.
# CEREBRO_DB_URL=file:./cerebro.db
# CEREBRO_DB_AUTH_TOKEN=

# ── Notion (optional, inbox/outbox) ───────────────────────────────
# Internal integration secret from notion.so → Settings → Integrations.
# CereBro never reads or stores this through the chat — set it here only.
# NOTION_TOKEN=
# NOTION_INBOX_DATABASE_ID=
# NOTION_OUTBOX_DATABASE_ID=

# ── Drive vault (optional) ────────────────────────────────────────
# Absolute path to a Google Drive synced folder. CereBro writes outputs
# and source captures into subdirs under this path.
# CEREBRO_VAULT_DIR=/Users/you/Library/CloudStorage/GoogleDrive-…/CereBro

# ── Upstream MySQL stub (unused by CereBro V1, kept for fork compat) ──
DATABASE_URL=mysql://user:password@host:3306/claude_dungeon

# Session signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-random-secret-here

# Optional: Manus OAuth (leave blank to disable auth)
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
